{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://muonium.ai/schemas/execution-attempt.schema.json",
  "title": "Higgs Execution Attempt Summary",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "attempt_id",
    "ticket_id",
    "started_at",
    "ended_at",
    "final_result"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "run_id": {
      "type": "string"
    },
    "attempt_id": {
      "type": "string"
    },
    "ticket_id": {
      "type": "string"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "ended_at": {
      "type": "string",
      "format": "date-time"
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "final_result": {
      "type": "string",
      "enum": [
        "succeeded",
        "failed",
        "blocked",
        "skipped"
      ]
    },
    "provider": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "tool_call_count": {
      "type": "integer",
      "minimum": 0
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0
    },
    "usage": {
      "$ref": "common-defs.schema.json#/$defs/usage"
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "$ref": "common-defs.schema.json#/$defs/artifactRef"
      }
    },
    "error": {
      "$ref": "common-defs.schema.json#/$defs/errorInfo"
    }
  },
  "additionalProperties": false
}